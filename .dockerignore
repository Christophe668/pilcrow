# Keep the build context lean — Docker COPY . . pulls everything not listed here.

# Dev artifacts
node_modules
.expo
.expo-shared
dist
ios
android
build
coverage

# Tests aren't needed at build time, but they're cheap to copy and
# Metro's resolver doesn't follow them. Leaving them in keeps `pnpm
# install --frozen-lockfile` happy without surprises.
# tests/  ← intentionally NOT ignored

# Local env / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# Git
.git
.gitignore
.github

# Worktrees and agent state
.claude

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker artifacts (don't recursively copy them into the image)
Dockerfile
docker-compose*.yml
.dockerignore

# Misc local
prototypes
wallabag-prototype.html
README.md
